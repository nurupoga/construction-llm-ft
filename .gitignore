# ================
# Data files
# ================
# RETIO 過去問PDFは著作権配慮で commit しない。
# manifest.json のみ commit する（URL/SHA256/メタデータ）。
data/raw/**/*.pdf
data/raw/**/*.PDF

# PDFから抽出したテキスト・画像（中間生成物）
data/raw/**/extracted/
data/raw/**/*.txt
data/raw/**/*.png
data/raw/**/*.jpg
data/raw/**/*.tif
data/raw/**/*.tiff

# 学習用JSONL・評価セットも本文を含むため非コミット
data/jsonl/**/*.jsonl
data/jsonl/**/*.tmp
data/eval/**/*.jsonl
data/eval/**/*.tmp

# 中間構造化JSON（問題本文を含むため非コミット、manifest.json は除外しない）
data/jsonl/intermediate/*.json
!data/jsonl/intermediate/manifest.json

# MCP cipher のローカルセッションDB
data/cipher-sessions.db
data/cipher-sessions.db-shm
data/cipher-sessions.db-wal

# ================
# Secrets / Env
# ================
.env
.env.local
.env.*.local
*.key
*.pem
secrets/
credentials.json
